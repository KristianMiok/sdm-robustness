# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual envs ---
venv/
env/
ENV/
.venv/

# --- PyCharm ---
.idea/
*.iml
*.iws
out/

# --- VS Code (if anyone strays) ---
.vscode/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_meta

# --- Testing / linting ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.ruff_cache/
.mypy_cache/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*~

# --- DATA (never commit) ---
# Full data directory ignored, keep structure via .gitkeep files
data/raw/*
data/interim/*
data/processed/*
data/outputs/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/outputs/.gitkeep
!data/README.md

# --- RESULTS (large, per-run; regenerate from code) ---
results/task1_audit/*
results/task5_execution/*
results/task6_analysis/*
results/figures/*
!results/task1_audit/.gitkeep
!results/task5_execution/.gitkeep
!results/task6_analysis/.gitkeep
!results/figures/.gitkeep

# --- Large binary formats ---
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.npz

# Allow small test fixtures
!tests/fixtures/*.parquet
!tests/fixtures/*.csv

# --- Logs ---
*.log
logs/

# --- Secrets ---
.env
.env.local
configs/paths.local.yaml
